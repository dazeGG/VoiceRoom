{
  "name": "voice-room",
  "version": "1.6.1",
  "private": true,
  "description": "Simple link-based LiveKit voice chat with screen sharing.",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:web": "vite",
    "dev:livekit": "docker run --rm -p 7880:7880 -p 7881:7881 -p 7882:7882/udp livekit/livekit-server:latest --dev --bind 0.0.0.0",
    "build": "vite build",
    "check": "node --check server.js && node --check public/audio-gate.worklet.js && node --check public/desktop-audio-source.worklet.js && tsc --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "livekit-server-sdk": "^2.15.4"
  },
  "devDependencies": {
    "livekit-client": "^2.19.2",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.20.2",
    "npm": "10.8.2"
  },
  "license": "MIT"
}
