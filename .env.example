DOMAIN=voice.example.com
LIVEKIT_DOMAIN=livekit.voice.example.com
LIVEKIT_URL=wss://livekit.voice.example.com
# Dev compose browser URL for LiveKit. If LIVEKIT_HTTP_PORT is changed, set this too.
# LIVEKIT_PUBLIC_URL=ws://localhost:7880

# Generate both with random values, for example:
# openssl rand -hex 12
# openssl rand -hex 32
LIVEKIT_API_KEY=change-me-livekit-key
LIVEKIT_API_SECRET=change-me-livekit-secret
LIVEKIT_TOKEN_TTL_SECONDS=21600
LIVEKIT_ROOM_PREFIX=voice-room-

# PostgreSQL persistence. docker-compose.yml uses POSTGRES_* to build DATABASE_URL
# unless DATABASE_URL is set explicitly.
POSTGRES_DB=voice_room
POSTGRES_USER=voice_room
POSTGRES_PASSWORD=change-me-postgres-password
# DATABASE_URL=postgres://voice_room:change-me-postgres-password@postgres:5432/voice_room
# API integration tests require an admin-capable PostgreSQL URL and create isolated databases.
# TEST_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:55432/postgres

# Trust X-Forwarded-For only behind a trusted reverse proxy (e.g. Caddy in docker-compose).
TRUST_PROXY=false

MAX_ROOM_PEERS=12
MAX_ROOMS=100
MAX_EMPTY_ROOMS_PER_IP=3
ROOM_IDLE_TTL_MS=900000
ROOM_PRUNE_INTERVAL_MS=60000

ROOM_CHAT_TTL_MS=604800000
ROOM_CHAT_MAX_MESSAGES=500
ROOM_CHAT_RATE_LIMIT=60
ROOM_CHAT_RATE_WINDOW_MS=60000

ROOM_CREATE_POW_DIFFICULTY=14
ROOM_CREATE_POW_TTL_MS=120000
ROOM_CREATE_RATE_LIMIT=20
ROOM_CREATE_RATE_WINDOW_MS=60000

# Accounts & sessions. The session cookie is HttpOnly + SameSite=Lax and is
# marked Secure automatically in production (NODE_ENV=production); override with
# SESSION_COOKIE_SECURE if you terminate TLS elsewhere.
SESSION_TTL_MS=2592000000
# SESSION_COOKIE_SECURE=true
AUTH_RATE_LIMIT=30
AUTH_RATE_WINDOW_MS=60000

# Друзья и личные сообщения. Отправка DM и заявок в друзья ограничена rate limit
# на пользователя; число одновременных realtime (SSE) подключений на аккаунт
# ограничено MAX_REALTIME_STREAMS_PER_USER.
DM_RATE_LIMIT=30
DM_RATE_WINDOW_MS=10000
FRIEND_REQUEST_RATE_LIMIT=20
FRIEND_REQUEST_RATE_WINDOW_MS=60000
MAX_REALTIME_STREAMS_PER_USER=8

HOST=127.0.0.1
SOCKET_PATH=

DESKTOP_RELEASE_REPO=dazeGG/VoiceRoomDesktop
DESKTOP_RELEASE_CACHE_MS=600000
GITHUB_TOKEN=
